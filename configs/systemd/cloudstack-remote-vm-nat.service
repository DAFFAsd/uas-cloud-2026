[Unit]
Description=CloudStack remote VM NAT from cloudbr0 to Wi-Fi uplink
After=network-online.target NetworkManager-wait-online.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/cloudstack-remote-vm-nat.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
